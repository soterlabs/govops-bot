{
  "display_information": {
    "name": "redline-bot",
    "description": "Sky Governance Spell Review bot (redline)",
    "background_color": "#1d1d1d"
  },
  "features": {
    "bot_user": {
      "display_name": "redline-bot",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/redline-schedule",
        "description": "Show the Spell Review schedule",
        "should_escape": false
      },
      {
        "command": "/redline-next",
        "description": "Show the next scheduled event",
        "should_escape": false
      },
      {
        "command": "/redline-help",
        "description": "List available redline-bot commands",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": ["chat:write", "commands"]
    }
  },
  "settings": {
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
